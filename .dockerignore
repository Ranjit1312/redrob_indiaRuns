# Keep the image lean. NOTE (v7): unlike v5, the rank step DOES read the
# artifacts_v7/*.npy embeddings (features.py builds the dense facet channel from
# job_embeddings.npy @ jd_vectors.npy), so artifacts_v7/ is shipped IN FULL in the
# RANK / SERVE images — do not exclude it.

# Version control / planning
.git
.gitignore
.gitattributes
.github

# v5 implementation + its artifacts (archived; not used by any v7 image)
archived/
versions/

# Large mounted input — candidates.jsonl is bind-mounted at run time (RANK /
# PRECOMPUTE); the SERVE image ranks the bundled demo pool instead.
candidates.jsonl
top100candidates.jsonl

# Stale / other-version artifact dirs (the live one is artifacts_v7/)
artifacts_full/
artifacts_v6/
artifacts/
artifacts_smoke/

# Python / env / test scratch
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
tests/

# Docs / scratch not needed at runtime
*.docx
*.md
report*.html
docs/
out/
submission_assets/
rank_telemetry.json
