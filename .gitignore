# --- large organiser-provided input (regenerable / not ours) ---
candidates.jsonl
sample_candidates.json.gz

# --- derived embeddings: ~620 MB, regenerable via precompute.py (we ship the
#     script, not the blob). The ~17 MB rank-step parquets/model/json ARE committed. ---
artifacts_full/*.npy
artifacts_full/_incremental/
artifacts_v6/
artifacts/
artifacts_smoke/

# --- iteration source folder: the history is encoded as commits, not this dir ---
versions/

# --- staging area for the replay runbook (final README etc.); never committed ---
submission_assets/
COMMANDS.md

# --- python / env ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
.pytest_cache/

# --- run/telemetry scratch + diagnostics (regenerated each run) ---
rank_telemetry.json
telemetry.json
telemetry.docker.json
top100candidates.jsonl
submission_blend.csv
resource_log.json
*.log
out/
out_docker/
hf_space_build/

# --- stray dot-less duplicates of dotfiles (accidental copies; delete them) ---
/dockerignore
/gitignore
/gitattributes

# --- docs/binaries we don't track ---
*.docx
report*.html
rec*.txt
docs_txt/
d_tmp*
f_tmp*

# --- OS / IDE ---
.DS_Store
.vscode/
.idea/
*.swp

# --- artifacts_v7: only the two big embedding blobs are >100MB (GitHub's hard
#     limit) and are REGENERATED by precompute (embed_candidates.py). Everything
#     else in artifacts_v7/ (parquets, model.txt, *.json, *.yaml, jd_vectors.npy,
#     job_offsets.npy) is <100MB and IS committed, so the rank step's non-embedding
#     inputs ship with the repo. ---
artifacts_v7/job_embeddings.npy
artifacts_v7/summary_embeddings.npy
artifacts_v7/_incremental/
